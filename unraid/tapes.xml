<?xml version="1.0"?>
<Container version="2">
  <Name>tapes</Name>
  <Repository>ghcr.io/laermannjan/tapes:latest</Repository>
  <Registry>https://github.com/laermannjan/tapes</Registry>
  <Branch>
    <Tag>latest</Tag>
    <TagDescription>Latest stable release</TagDescription>
  </Branch>
  <Network>bridge</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/laermannjan/tapes/issues</Support>
  <Project>https://github.com/laermannjan/tapes</Project>
  <Overview>
    Organize your movie and TV show files. Tapes identifies media files using TMDB,
    renames them according to your templates, and copies/moves/links them into your
    library. Runs as a web UI with automatic processing - confident matches are
    handled automatically, uncertain ones wait for you in the browser.
  </Overview>
  <Category>MediaApp:Other</Category>
  <WebUI>http://[IP]:[PORT:8080]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/laermannjan/tapes/main/unraid/tapes.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/laermannjan/tapes/main/docs/icon.png</Icon>
  <GitHub>https://github.com/laermannjan/tapes</GitHub>
  <ReadMe>https://raw.githubusercontent.com/laermannjan/tapes/main/README.md</ReadMe>
  <Date>2026-03-22</Date>
  <Changes>
### 2026-03-22
- Initial release
- Web UI via textual-serve
- Auto-commit with debounce
- Directory polling
- Structured JSON logging
- Conflict resolution (auto/skip/keep_all)
  </Changes>
  <ExtraParams>--restart unless-stopped</ExtraParams>
  <PostArgs>--serve --auto-commit</PostArgs>
  <Config
    Name="WebUI Port"
    Target="8080"
    Default="8080"
    Mode="tcp"
    Description="Port for the web interface"
    Type="Port"
    Display="always"
    Required="true"
    Mask="false"
  >8080</Config>
  <Config
    Name="Source Directory"
    Target="/data/source"
    Default="/mnt/user/media/unsorted"
    Mode="rw"
    Description="Directory to scan for media files"
    Type="Path"
    Display="always"
    Required="true"
    Mask="false"
  >/mnt/user/media/unsorted</Config>
  <Config
    Name="Movies Library"
    Target="/data/movies"
    Default="/mnt/user/media/movies"
    Mode="rw"
    Description="Movies library directory"
    Type="Path"
    Display="always"
    Required="true"
    Mask="false"
  >/mnt/user/media/movies</Config>
  <Config
    Name="TV Library"
    Target="/data/tv"
    Default="/mnt/user/media/tv"
    Mode="rw"
    Description="TV shows library directory"
    Type="Path"
    Display="always"
    Required="true"
    Mask="false"
  >/mnt/user/media/tv</Config>
  <Config
    Name="TMDB Token"
    Target="TAPES_METADATA__TMDB_TOKEN"
    Default=""
    Description="TMDB read access token (required - get one free at themoviedb.org)"
    Type="Variable"
    Display="always"
    Required="true"
    Mask="true"
  ></Config>
  <Config
    Name="Poll Interval"
    Target="TAPES_MODE__POLL_INTERVAL"
    Default="10"
    Description="How often to check for new files (seconds, 0 to disable)"
    Type="Variable"
    Display="advanced"
    Required="false"
    Mask="false"
  >10</Config>
  <Config
    Name="File Operation"
    Target="TAPES_LIBRARY__OPERATION"
    Default="copy"
    Description="How to process files: copy, move, link, or hardlink"
    Type="Variable"
    Display="advanced"
    Required="false"
    Mask="false"
  >copy</Config>
  <Config
    Name="Conflict Resolution"
    Target="TAPES_LIBRARY__CONFLICT_RESOLUTION"
    Default="auto"
    Description="How to handle conflicts: auto (largest wins), skip, or keep_all"
    Type="Variable"
    Display="advanced"
    Required="false"
    Mask="false"
  >auto</Config>
  <Config
    Name="Language"
    Target="TAPES_METADATA__LANGUAGE"
    Default=""
    Description="TMDB language code (e.g. de, fr, en-US). Empty for default."
    Type="Variable"
    Display="advanced"
    Required="false"
    Mask="false"
  ></Config>
</Container>
