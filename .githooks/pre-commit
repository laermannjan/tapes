#!/usr/bin/env bash
set -e

# Only check staged Python files
staged=$(git diff --cached --name-only --diff-filter=ACM -- '*.py')
if [ -z "$staged" ]; then
    exit 0
fi

echo "ruff check..."
uv tool run ruff check $staged

echo "ruff format..."
uv tool run ruff format --check $staged

echo "ty check..."
uv tool run ty check
